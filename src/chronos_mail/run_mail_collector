from collector import *
from ms_graph import get_access_token
from datetime import datetime

def main():
    token = get_access_token()

    headers = {
        "Authorization": f"Bearer {token}"
    }

    last_check_time = None
    seen_ids = []

    messages_vinted = fetch_mails(
        headers,
        "AQMkADAwATM0MDAAMS0zZWUANi03YThjLTAwAi0wMAoALgAAA2jo-u_DmBhJsGyXYmHbLm0BAAOdbV2hdLRMoaPTCu6-rbQAA5S9_18AAAA="
    )

    current_max = None

    for msg in messages_vinted:
        date_string = msg.get("receivedDateTime")
        if not date_string:
            continue

        date_object = datetime.strptime(date_string, "%Y-%m-%dT%H:%M:%SZ")
        
        if last_check_time is not None and date_object <= last_check_time:
            break
        
        if msg["id"] in seen_ids:
            continue
        
        #! insert processing of mails
        print("NEW:", msg["subject"])

        seen_ids.append(msg["id"])
        
        if current_max is None or date_object > current_max:
            current_max = date_object
            

    last_check_time = current_max

    print(last_check_time)
    
    
if __name__ == "__main__":
    main()